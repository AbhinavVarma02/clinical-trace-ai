# =============================================================
# Clinical-Trace AI - Environment Configuration
# =============================================================
# Copy this file to .env and fill in your own values:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# All values below are placeholders only.
# =============================================================

# OpenAI (optional: needed for LLM explanations, not for predictions)
OPENAI_API_KEY=your_openai_api_key_here

# LangSmith tracing (optional: needed for LLM tracing)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=clinical-trace-ai

# Application
API_HOST=0.0.0.0
API_PORT=8000

# Model configuration
MODEL_PATH=models/best_model.joblib
PIPELINE_PATH=models/preprocessing_pipeline.joblib
RISK_THRESHOLD=0.35
